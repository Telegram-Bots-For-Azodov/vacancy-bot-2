# Telegram bot tokeni (@BotFather dan oling)
BOT_TOKEN=123456:ABC-DEF...

# Telegram bloklangan serverlar uchun proxy (ixtiyoriy).
# Masalan: http://user:pass@host:port  yoki  socks5://host:port
TELEGRAM_PROXY=

# Superadmin Telegram ID lar (hududlarni boshqaradi)
SUPERADMIN_IDS=123456789

# Yordamchi admin Telegram ID lar (vergul bilan ajrating)
ADMIN_IDS=

# abkm.mehnat.uz API uchun Bearer token (vaqti-vaqti bilan yangilanadi)
ABKM_TOKEN=TOKEN_HERE

# Standart yil/oy (bo'sh qolsa joriy sana ishlatiladi)
DEFAULT_YEAR=
DEFAULT_MONTH=

DB_PATH=vacancy.db
LOG_LEVEL=INFO

# --- Local Bot API server + Webhook ---
TELEGRAM_API_BASE=http://telegram-bot-api:8081
WEBHOOK_MODE=1
WEBHOOK_URL=https://azodov.uz
WEBHOOK_PATH=/webhook/<MAXFIY_TASODIFIY_YOL>
WEBHOOK_SECRET=<MAXFIY_TOKEN>
WEBAPP_PORT=8080
